    <text>
        <body>
            <schemaSpec start="TEI teiCorpus" ident="antidote" source="teipublisher.odd"> <elementSpec ident="title" mode="change">
                    <model predicate="ancestor::body" behaviour="inline">
            <outputRendition xml:space="preserve">
            
            
            
            
            
            text-decoration:underline;
text-decoration-thickness:5%;
text-underline-offset:3px
            
            
            
            
            
            </outputRendition>
        </model>
                </elementSpec>
                <elementSpec ident="hi rend" mode="add"/>
                <elementSpec ident="unclear" mode="change">
                    <model behaviour="alternate">
            <param name="alternate" value="@type"/>
            <param name="default" value="."/>
        </model>
                </elementSpec>
                <elementSpec ident="quote" mode="change">
                    <model behaviour="alternate">
            <param name="alternate" value="@source"/>
            <param name="default" value="."/>
            <outputRendition xml:space="preserve">
            font-style: Italic;
            </outputRendition>
        </model>
                </elementSpec>
            <elementSpec ident="supplied" mode="change">
                    <model behaviour="alternate">
            <param name="alternate" value="@desc"/>
            <param name="default" value="."/>
            <outputRendition xml:space="preserve">
            color:lightgrey
            </outputRendition>
        </model>
                </elementSpec>
                <elementSpec ident="body" mode="change">
                    <model behaviour="inline">
            <outputRendition xml:space="preserve">
            font-style:oswald
            </outputRendition>
        </model>
                </elementSpec>
                <elementSpec ident="sic" mode="change">
                    <model behaviour="alternate">
            <param name="default" value="."/>
            <param name="alternate" value="@descr"/>
            <outputRendition xml:space="preserve">
            color:red
            </outputRendition>
        </model>
                </elementSpec>
                <elementSpec ident="titleStmt" mode="change">
                    <modelSequence>
            <model behaviour="heading">
                <param name="content" value="title[not(@type)]"/>
                <outputRendition xml:space="preserve">
                
                font-size: 34px;
text-align: center;
color:darkred;
                
                </outputRendition>
            </model>
            <model behaviour="heading">
                <param name="content" value="author[not(@type)]"/>
                <outputRendition xml:space="preserve">
                
                font-size: 24px;
text-align: center;
color: grey;
                
                </outputRendition>
            </model>
        </modelSequence>
                    <model behaviour="heading">
            <param name="content" value="title[not(@type)]"/>
            <outputRendition xml:space="preserve">
            
            font-size: 34px;
text-align: center;
            
            </outputRendition>
        </model>
                </elementSpec>
                <elementSpec ident="lb" mode="change">
                    <modelSequence>
            <model predicate="@rend=&#34;bold&#34;" behaviour="inline">
                <outputRendition xml:space="preserve">
                font-weight:bold
                </outputRendition>
            </model>
            <model behaviour="break">
                <param name="type" value="'line'"/>
                <param name="label" value="@n"/>
            </model>
            <model predicate="rend=&#34;bold&#34;" behaviour="inline">
                <outputRendition xml:space="preserve">
                font-weight:bold
                </outputRendition>
            </model>
            <model behaviour="inline">
                <param name="content" value="@n"/>
                <outputRendition xml:space="preserve">
                color: green;
font-size: 14px
                </outputRendition>
            </model>
        </modelSequence>
                    <model behaviour="break" useSourceRendition="true">
            <param name="type" value="'line'"/>
            <param name="label" value="@n"/>
        </model>
                </elementSpec>
                <elementSpec ident="pb" mode="change">
                    <model behaviour="break" useSourceRendition="true">
            <param name="type" value="'page'"/>
            <param name="label" value="(concat(if(@n) then concat(@n,' ') else '',if(@facs) then                   concat('@',@facs) else ''))"/>
            <outputRendition xml:space="preserve">
            display: block; margin-left: 2pt; color: lightgrey; float: right;
            </outputRendition>
            <outputRendition xml:space="preserve" scope="before">
            content: '[fol.';
            </outputRendition>
            <outputRendition xml:space="preserve" scope="after">
            content: ']';
            </outputRendition>
        </model>
                </elementSpec>
            <elementSpec ident="msIdentifier" mode="change"/>
            <elementSpec ident="msDesc" mode="add"/>
                <elementSpec ident="sourceDesc" mode="change"/>
                <!-- testing expansion visualising -->
    <elementSpec ident="ex" mode="change">
                    <model behaviour="inline">
            <outputRendition xml:space="preserve">
            background-color: transparent;
            </outputRendition>
            <outputRendition xml:space="preserve">
            color: green;
            </outputRendition>
        </model>
                </elementSpec>
    <!-- /testing expansion visualising -->
            <elementSpec ident="location" mode="add">
    </elementSpec>
            </schemaSpec>
            <!-- Underline text with @rendition="underline" -->
                <elementSpec ident="hi" mode="change">
                <model predicate="@rend=&#34;underline&#34;" behaviour="inline">
            <outputRendition xml:space="preserve">
            
            
            
            
            
            
            
            text-decoration:underline;
text-decoration-thickness:3%;
text-decoration-color:grey;
text-underline-offset:3px
            
            
            
            
            
            
            
            </outputRendition>
        </model>
            </elementSpec>
        </body>
